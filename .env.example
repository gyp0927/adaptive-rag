# Application
APP_NAME=adaptive-rag
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Vector Database (Qdrant)
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=6333
VECTOR_DB_COLLECTION=adaptive_rag

# Metadata Database (PostgreSQL)
METADATA_DB_URL=postgresql+asyncpg://rag:rag_password@localhost:5432/adaptive_rag

# Cache (Redis)
CACHE_URL=redis://localhost:6379/0

# Document Store
DOCUMENT_STORE_TYPE=local
DOCUMENT_STORE_PATH=./data/documents

# Embedding (choose one)
# Option 1: OpenAI (paid, cloud)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Option 2: sentence-transformers (free, local)
# EMBEDDING_PROVIDER=sentence-transformers
# LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2   # 384d, fast
# LOCAL_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2  # 768d, better quality
# LOCAL_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5                    # 1024d, Chinese optimized
# EMBEDDING_DIMENSION=384
# LOCAL_EMBEDDING_DEVICE=cpu

# LLM (OpenAI - required for compression/decompression)
LLM_API_KEY=sk-your-openai-api-key
LLM_PROVIDER=openai
COMPRESSION_MODEL=gpt-4o-mini
DECOMPRESSION_MODEL=gpt-4o

# Tier Configuration
HOT_TO_COLD_THRESHOLD=0.25
COLD_TO_HOT_THRESHOLD=0.7
COLD_TIER_COMPRESSION_RATIO=0.2

# Frequency Tracking
DECAY_HALF_LIFE_HOURS=72.0
QUERY_CLUSTERING_THRESHOLD=0.85

# Migration
MIGRATION_BATCH_SIZE=100
MIGRATION_INTERVAL_MINUTES=60
